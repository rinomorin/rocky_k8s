---
apiVersion: v1
kind: Namespace
metadata:
  name: portainer
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: dex-service-account
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: dex-storage-role
rules:
  - apiGroups: ["apiextensions.k8s.io"]
    resources: ["customresourcedefinitions"]
    verbs: ["*"]
  - apiGroups: ["dex.coreos.com"]
    resources: ["*"]
    verbs: ["*"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: dex-storage-binding
subjects:
- kind: ServiceAccount
  name: dex-service-account
  namespace: kube-system
roleRef:
  kind: ClusterRole
  name: dex-storage-role
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: dex-config
  namespace: kube-system
data:
  config.yaml: |
    issuer: http://{{ lookup('env', 'p_zone') }}
    storage:
      type: kubernetes
      config:
        inCluster: true
    web:
      http: 0.0.0.0:5556
    
    connectors:
    - type: ldap
      id: active-directory
      name: Active Directory
      config:
        host: "{{ ad_domain_controller_ip }}:{{ ad_domain_ldap_port }}"
        insecureNoSSL: true
        bindDN: "{{ ad_bind_dn }}"
        bindPW: "{{ ad_bind_password }}"
        userSearch:
          baseDN: "ou=Users,{{ ad_base_dn }}"
          filter: "(objectClass=person)"
          username: sAMAccountName
          idAttr: sAMAccountName
          emailAttr: mail
        groupSearch:
          baseDN: "ou=Groups,{{ ad_base_dn }}"
          filter: "(objectClass=group)"
          userMatchers:
          - userAttr: DN
            groupAttr: member
          nameAttr: cn

    staticClients:
    - id: portainer-client
      redirectURIs:
      - 'http://{{  'p_zone' }}'
      name: 'Portainer GUI'
      secret: portainer-super-secret-key
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: dex
  namespace: kube-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: dex
  template:
    metadata:
      labels:
        app: dex
    spec:
      serviceAccountName: dex-service-account
      nodeSelector:
        kubernetes.io/os: linux
      containers:
      - name: dex
        image: ghcr.io/dexidp/dex:v2.38.0
        command: ["dex", "serve", "/etc/dex/cfg/config.yaml"]
        ports:
        - name: http
          containerPort: 5556
        volumeMounts:
        - name: config
          mountPath: /etc/dex/cfg
      volumes:
      - name: config
        configMap:
          name: dex-config
---
apiVersion: v1
kind: Service
metadata:
  name: dex
  namespace: kube-system
spec:
  ports:
  - name: http
    port: 5556
    targetPort: 5556
  selector:
    app: dex
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: portainer-pv
spec:
  capacity:
    storage: 10Gi
  volumeMode: Filesystem
  accessModes:
  - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: ceph-nfs-storage
  nfs:
    server: 10.0.0.51
    path: /
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: portainer-pvc
  namespace: portainer
spec:
  accessModes:
  - ReadWriteOnce
  storageClassName: ceph-nfs-storage
  volumeName: portainer-pv
  resources:
    requests:
      storage: 10Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: portainer
  namespace: portainer
spec:
  replicas: 1
  selector:
    matchLabels:
      app: portainer
  template:
    metadata:
      labels:
        app: portainer
    spec:
      nodeSelector:
        kubernetes.io/os: linux
        
      securityContext:
        fsGroup: 60000
        runAsUser: 60000

      # --- ADD THIS AUTOMATED WORKSPACE INITIALIZATION BLOCK ---
      initContainers:
      - name: volume-permissions-fix
        image: alpine:latest
        command: ["sh", "-c", "mkdir -p /data/certs /data/db && chown -R 60000:60000 /data && chmod -R 775 /data"]
        securityContext:
          runAsUser: 0  # Runs temporarily as root to cut through the NFS mount lock
        volumeMounts:
        - name: portainer-data
          mountPath: /data

      containers:
      - name: portainer
        image: portainer/portainer-ce:latest
        ports:
        - containerPort: 9000
          name: http
        - containerPort: 9443
          name: https
        volumeMounts:
        - name: portainer-data
          mountPath: /data
      volumes:
      - name: portainer-data
        persistentVolumeClaim:
          claimName: portainer-pvc
---
apiVersion: v1
kind: Service
metadata:
  name: portainer
  namespace: portainer
spec:
  ports:
  - name: http
    port: 9000
    targetPort: 9000
  selector:
    app: portainer
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: ad-cluster-admins
subjects:
- kind: Group
  name: "Domain Admins"
  apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: cluster-admin
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: platform-identity-ingress
  namespace: kube-system
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "false"
spec:
  ingressClassName: nginx
  rules:
  - host: "dex.api.{{c_zone}}"
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: dex
            port:
              number: 5556
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: portainer-gui-ingress
  namespace: portainer
  annotations:
    nginx.ingress.kubernetes.io/ssl-redirect: "false"
spec:
  ingressClassName: nginx
  rules:
  - host: "portainer.api.{{c_zone}}"
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: portainer
            port:
              number: 9000
