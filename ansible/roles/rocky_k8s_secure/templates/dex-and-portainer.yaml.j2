---
apiVersion: v1
kind: Namespace
metadata:
  name: portainer
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: dex-service-account
  namespace: kube-system
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: dex-storage-role
rules:
- apiGroups: ["apiextensions.k8s.io"]
  resources: ["customresourcedefinitions"]
  verbs: ["get", "list", "watch", "create"]
- apiGroups: ["://coreos.com"]
  resources: ["*"]
  verbs: ["*"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: dex-storage-binding
subjects:
- kind: ServiceAccount
  name: dex-service-account
  namespace: kube-system
roleRef:
  kind: ClusterRole
  name: dex-storage-role
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: dex-config
  namespace: kube-system
data:
  config.yaml: |
    issuer: http://{{ target_ingress_vip }}:31156/dex
    storage:
      type: kubernetes
      config:
        inCluster: true
    web:
      http: 0.0.0.0:5556
    
    connectors:
    - type: ldap
      id: active-directory
      name: Active Directory
      config:
        host: "{{ ad_domain_controller_ip }}:{{ ad_domain_ldap_port }}"
        insecureNoSSL: true
        bindDN: "{{ ad_bind_dn }}"
        bindPW: "{{ ad_bind_password }}"
        userSearch:
          baseDN: "ou=Users,{{ ad_base_dn }}"
          filter: "(objectClass=person)"
          username: sAMAccountName
          idAttr: sAMAccountName
          emailAttr: mail
        groupSearch:
          baseDN: "ou=Groups,{{ ad_base_dn }}"
          filter: "(objectClass=group)"
          userMatchers:
          - userAttr: DN
            groupAttr: member
          nameAttr: cn

    staticClients:
    - id: portainer-client
      redirectURIs:
      - 'http://{{ target_ingress_vip }}:30090/'
      name: 'Portainer GUI'
      secret: portainer-super-secret-key
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: dex
  namespace: kube-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: dex
  template:
    metadata:
      labels:
        app: dex
    spec:
      serviceAccountName: dex-service-account
      nodeSelector:
        kubernetes.io/os: linux
      containers:
      - name: dex
        image: ghcr.io/dexidp/dex:v2.38.0
        command: ["dex", "serve", "/etc/dex/cfg/config.yaml"]
        ports:
        - name: http
          containerPort: 5556
        volumeMounts:
        - name: config
          mountPath: /etc/dex/cfg
      volumes:
      - name: config
        configMap:
          name: dex-config
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: portainer
  namespace: portainer
spec:
  replicas: 1
  selector:
    matchLabels:
      app: portainer
  template:
    metadata:
      labels:
        app: portainer
    spec:
      nodeSelector:
        kubernetes.io/os: linux
      
      # 1. Bypasses Rocky Linux SELinux and updates host path ownership natively
      securityContext:
        fsGroup: 60000
        runAsUser: 60000

      containers:
      - name: portainer
        image: portainer/portainer-ce:latest
        ports:
        - containerPort: 9000
          name: http
        - containerPort: 9443
          name: https
        volumeMounts:
        - name: portainer-data
          mountPath: /data
      volumes:
      - name: portainer-data
        hostPath:
          path: /var/lib/portainer
          type: DirectoryOrCreate

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: dex-storage-role
rules:
  - apiGroups: ["apiextensions.k8s.io"]
    resources: ["customresourcedefinitions"]
    verbs: ["*"] # ◄ Changed from restricted list to allow everything
  - apiGroups: ["dex.coreos.com"]
    resources: ["*"]
    verbs: ["*"]
