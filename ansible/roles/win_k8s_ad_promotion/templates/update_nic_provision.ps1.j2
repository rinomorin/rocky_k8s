$ErrorActionPreference = 'Stop'
$ProgressPreference = 'SilentlyContinue'

# ==============================
# CONFIG (rendered by Ansible)
# ==============================
$ProvisionIP      = '{{ provision_ip }}'
$PrefixLength     = {{ provision_prefix | default(24) }}
$ProvisionGateway = '{{ provision_gw }}'

# ==============================
# 1. Find target NIC (The "Provisioning" NIC, non-172)
# ==============================
$Nic = $null

foreach ($n in Get-NetAdapter) {
    if ($n.Status -ne 'Up' -or $n.Virtual -or $n.Name -match 'Loopback') { continue }

    $ips = Get-NetIPAddress `
            -InterfaceIndex $n.IfIndex `
            -AddressFamily IPv4 `
            -ErrorAction SilentlyContinue |
           Select-Object -ExpandProperty IPAddress

    if (-not ($ips | Where-Object { $_ -like '172.*' })) {
        $Nic = $n
        break
    }
}

if (-not $Nic) {
    Write-Error 'No eligible non-172 NIC found'
    exit 1
}

$IfIndex = $Nic.IfIndex
$IfName  = $Nic.Name

# ==============================
# 2. IDPOTENCY CHECK
# ==============================
$ExistingIP = Get-NetIPAddress `
    -InterfaceIndex $IfIndex `
    -AddressFamily IPv4 `
    -ErrorAction SilentlyContinue |
    Where-Object {
        $_.IPAddress -eq $ProvisionIP -and
        $_.PrefixLength -eq $PrefixLength
    }

if ($ExistingIP) {
    Write-Host "IP $ProvisionIP already set on $IfName. Ensuring routes are correct..."
} else {
    # ==============================
    # 3. CONFIGURE NIC
    # ==============================
    Enable-NetAdapter -Name $IfName -Confirm:$false
    Set-NetIPInterface -InterfaceIndex $IfIndex -AddressFamily IPv4 -Dhcp Disabled

    # Remove existing IPs to ensure a clean assignment
    Get-NetIPAddress -InterfaceIndex $IfIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | 
        Remove-NetIPAddress -Confirm:$false

    # Assign static IP WITHOUT setting it as a Default Gateway
    New-NetIPAddress `
        -InterfaceIndex $IfIndex `
        -IPAddress $ProvisionIP `
        -PrefixLength $PrefixLength
}

# ==============================
# 4. ROUTE MANIPULATION (The Persistence Fix)
# ==============================

# Kill the persistent ghost route to 10.0.0.1
Write-Host "Removing persistent 10.0.0.1 gateway..."
route delete 0.0.0.0 mask 0.0.0.0 10.0.0.1 -p 2>$null

# Force 172.16.0.1 as the ONLY persistent default gateway
Write-Host "Setting 172.16.0.1 as the persistent default gateway..."
route add 0.0.0.0 mask 0.0.0.0 172.16.0.1 metric 10 -p

# ==============================
# 5. INTERFACE METRICS
# ==============================

# Find the 172.16.x.x (Management) NIC
$NatNic = Get-NetIPAddress -IPAddress "172.16.*" | Select-Object -First 1

if ($NatNic) {
    # Set Management NIC to high priority (Low Metric)
    Set-NetIPInterface -InterfaceIndex $NatNic.InterfaceIndex -InterfaceMetric 10
}

# Set Provisioning NIC to lower priority (High Metric)
Set-NetIPInterface -InterfaceIndex $IfIndex -InterfaceMetric 100

# Final summary for Ansible logs
Get-NetIPConfiguration | 
    Where-Object { $_.InterfaceIndex -eq $IfIndex -or ($NatNic -and $_.InterfaceIndex -eq $NatNic.InterfaceIndex) } |
    Select-Object InterfaceAlias, IPv4Address, IPv4DefaultGateway | 
    ConvertTo-Json -Compress