$ErrorActionPreference = 'Stop'
$ProgressPreference = 'SilentlyContinue'

# ==============================
# CONFIG (rendered by Ansible)
# ==============================
$ProvisionIP      = '{{ provision_ip }}'
$PrefixLength     = {{ provision_prefix | default(24) }}
$ProvisionGateway = '{{ provision_gw }}'

# ==============================
# 1. Find target NIC (non-172)
# ==============================
$Nic = $null
foreach ($n in Get-NetAdapter) {
    if ($n.Status -ne 'Up' -or $n.Virtual -or $n.Name -match 'Loopback') { continue }

    $ips = Get-NetIPAddress -InterfaceIndex $n.IfIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | Select-Object -ExpandProperty IPAddress
    if (-not ($ips | Where-Object { $_ -like '172.*' })) {
        $Nic = $n
        break
    }
}

if (-not $Nic) {
    Write-Error 'No eligible non-172 NIC found'
    exit 1
}

$IfIndex = $Nic.IfIndex
$IfName  = $Nic.Name

# ==============================
# 2. IDPOTENCY CHECK
# ==============================
$ExistingIP = Get-NetIPAddress -InterfaceIndex $IfIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue |
    Where-Object { $_.IPAddress -eq $ProvisionIP -and $_.PrefixLength -eq $PrefixLength }

$ExistingGW = Get-NetRoute -InterfaceIndex $IfIndex -DestinationPrefix '0.0.0.0/0' -ErrorAction SilentlyContinue |
    Where-Object { $_.NextHop -eq $ProvisionGateway }

if ($ExistingIP -and $ExistingGW) {
    # Already configured, just ensure metrics are correct before exiting
    $NatNic = Get-NetIPAddress -IPAddress "172.16.*" | Select-Object -First 1
    if ($NatNic) { Set-NetIPInterface -InterfaceIndex $NatNic.InterfaceIndex -InterfaceMetric 10 }
    Set-NetIPInterface -InterfaceIndex $IfIndex -InterfaceMetric 100
    exit 0
}

# ==============================
# 3. CLEANUP & PREP
# ==============================
Write-Host "Cleaning persistent routes and clearing existing IPs..."
route -f  # Wipe persistent route table to remove ghost 10.0.0.1 gateways

Enable-NetAdapter -Name $IfName -Confirm:$false
Set-NetIPInterface -InterfaceIndex $IfIndex -AddressFamily IPv4 -Dhcp Disabled

# Clear existing IPs on THIS specific NIC to prevent conflicts
Get-NetIPAddress -InterfaceIndex $IfIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | Remove-NetIPAddress -Confirm:$false

# ==============================
# 4. ASSIGN STATIC IP + GATEWAY
# ==============================
New-NetIPAddress `
    -InterfaceIndex $IfIndex `
    -IPAddress $ProvisionIP `
    -PrefixLength $PrefixLength `
    -DefaultGateway $ProvisionGateway

# ==============================
# 5. FORCE INTERFACE METRICS
# ==============================
# Maintenance (br-nat) gets Priority (Low Metric)
$NatNic = Get-NetIPAddress -IPAddress "172.16.*" | Select-Object -First 1
if ($NatNic) {
    Set-NetIPInterface -InterfaceIndex $NatNic.InterfaceIndex -InterfaceMetric 10
}

# Cluster Network gets Lower Priority (High Metric)
Set-NetIPInterface -InterfaceIndex $IfIndex -InterfaceMetric 100

Write-Host "NIC Configuration Complete."