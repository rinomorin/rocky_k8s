# Generated by Ansible - Generic Chrony Configuration
driftfile /var/lib/chrony/drift
makestep 1.0 3

{% set ipa_zone = '192.168.100.0/24' %}
{% set helper_zone = '10.0.0.0/24' %}

{# 1: Skip if this host is already a master/helper #}
{% if 'ipa' not in group_names and 'helpers' not in group_names %}

  {# Determine this node's connectivity #}
  {% set has_ipa_access = (ansible_host | default('') | ansible.utils.ipaddr(ipa_zone)) or (provider_ip | default('') | ansible.utils.ipaddr(ipa_zone)) %}
  {% set has_helper_access = (ansible_host | default('') | ansible.utils.ipaddr(helper_zone)) or (provision_ip | default('') | ansible.utils.ipaddr(helper_zone)) or (node_ip | default('') | ansible.utils.ipaddr(helper_zone)) %}

  {# 2 & 3: Add sources based on reachable zone #}
  {% if has_ipa_access %}
    {# Node is in 192.x zone - Pointing to IPA Masters #} 
    {% for host in groups['ipa'] %}
      {# Pull the 192.x address from the IPA host #}
server {{ hostvars[host]['ansible_host'] }} iburst
    {% endfor %}
  {% endif %}
  {% if has_helper_access %}
    {# Node is in 10.x zone - Pointing to Helper #}
    {% for host in groups['helpers'] %}
      {# Pull the 10.x (provision_ip) from the Helper host #}
server {{ hostvars[host]['provision_ip'] }} iburst
    {% endfor %}
  {% endif %}

{% endif %}

rtcsync