# --- NTP Source Selection ---

{% if ipa_cluster_role == 'primary' %}
# Primary Master: Syncs with NRC Canada
{% for ntp_host in nrc_ntp_list %}
server {{ ntp_host | trim }} iburst
{% endfor %}
{% else %}
# Replica/Helper: Syncs with Primary IPA ({{ ipa_primary_host }})
server {{ ipa_primary_host }} iburst

# Fallback to NRC if Primary is down
{% for ntp_host in nrc_ntp_list %}
server {{ ntp_host | trim }} iburst
{% endfor %}
{% endif %}

# --- Operational Settings ---
driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync

# --- Access Control ---
# Dynamically allowed subnets from KVM inventory
{% for net in hostvars['kvmdc01']['libvirt_networks'] %}
allow {{ net.cidr }}
{% endfor %}

# Serve time even if disconnected from upstream
local stratum {{ '10' if ipa_cluster_role == 'primary' else '11' }}