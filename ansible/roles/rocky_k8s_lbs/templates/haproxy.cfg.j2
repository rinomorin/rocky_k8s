global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect 10s
    timeout client  1m
    timeout server  1m

# --- K8S API SERVER (6443) ---
frontend k8s-api
    bind {{ k8s_api_vip }}:6443
    mode tcp
    option tcplog
    default_backend k8s-masters

backend k8s-masters
    mode tcp
    balance roundrobin
    option httpchk GET /healthz
    http-check expect status 200
    {% for host in groups['control_nodes'] %}
    server {{ host }} {{ hostvars[host].provision_ip }}:6443 check check-ssl verify none
    {% endfor %}

# --- INGRESS TRAFFIC (HTTPS - 443) ---
frontend k8s-ingress-https
    bind 192.168.100.30:443
    mode tcp
    default_backend k8s-ingress-backend-https

backend k8s-ingress-backend-https
    mode tcp
    balance roundrobin
    # We use the NodePort 31794 found in your previous describe output
    server msrlv9mast01 10.0.0.31:31794 check
    server msrlv9mast02 10.0.0.32:31794 check
    server msrlv9mast03 10.0.0.33:31794 check

# --- INGRESS TRAFFIC (HTTP - 80) ---
frontend k8s-ingress-http
    bind 192.168.100.30:80
    mode tcp
    default_backend k8s-ingress-backend-http

backend k8s-ingress-backend-http
    mode tcp
    balance roundrobin
    # We use the NodePort 31826 found in your previous describe output
    server msrlv9mast01 10.0.0.31:31826 check
    server msrlv9mast02 10.0.0.32:31826 check
    server msrlv9mast03 10.0.0.33:31826 check
    
# --- MAINTENANCE TRAFFIC ROUTING ---
frontend k8s_maint_front
    bind {{ k8s_maint_vip }}:6443
    mode tcp
    default_backend k8s_maint_back

backend k8s_maint_back
    mode tcp
    balance roundrobin
    # Routes only to your maintenance backend IP
    server master_maint {{ backend_maint_ip }}:6443 check

# --- MAINTENANCE HTTP TRAFFIC ---
frontend k8s-maint-http
    bind {{ k8s_maint_vip }}:80
    mode tcp
    default_backend k8s-maint-backend-http

backend k8s-maint-backend-http
    mode tcp
    balance roundrobin
    # Maintenance routes directly to the maintenance backend
    server master_maint {{ backend_maint_ip }}:31826 check

