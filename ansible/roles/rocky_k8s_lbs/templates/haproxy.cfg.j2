global
    log /dev/log local0
    log /dev/log local1 notice
    daemon

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect 10s
    timeout client  1m
    timeout server  1m

# --- K8S API SERVER (6443) ---
frontend k8s-api
    bind {{ k8s_api_vip }}:6443
    mode tcp
    option tcplog
    default_backend k8s-masters

backend k8s-masters
    mode tcp
    balance roundrobin
    option httpchk GET /healthz
    http-check expect status 200
    {% for host in groups['control_nodes'] %}
    server {{ host }} {{ hostvars[host].provision_ip }}:6443 check check-ssl verify none
    {% endfor %}

# --- INGRESS TRAFFIC (HTTPS - 443) ---
frontend k8s-ingress-https
    bind {{ k8s_api_vip }}:443
    mode tcp
    default_backend k8s-ingress-backend-https

backend k8s-ingress-backend-https
    mode tcp
    balance roundrobin
    {% for host in groups['control_nodes'] %}
    server {{ host }} {{ hostvars[host].provision_ip }}:30443 check
    {% endfor %}

# --- INGRESS TRAFFIC (HTTP - 80) ---
frontend k8s-ingress-http
    bind {{ k8s_api_vip }}:80
    mode tcp
    default_backend k8s-ingress-backend-http

backend k8s-ingress-backend-http
    mode tcp
    balance roundrobin
    {% for host in groups['control_nodes'] %}
    server {{ host }} {{ hostvars[host].provision_ip }}:30080 check
    {% endfor %}

# --- MAINTENANCE TRAFFIC (API - 5443) ---
frontend k8s_maint_front
    bind {{ k8s_maint_vip }}:5443
    mode tcp
    default_backend k8s_maint_back

backend k8s_maint_back
    mode tcp
    balance roundrobin
    server master_maint {{ backend_maint_ip }}:6443 check

# --- MAINTENANCE HTTP TRAFFIC (Port 80) ---
frontend k8s-maint-http
    bind {{ k8s_maint_vip }}:80
    mode tcp
    default_backend k8s-maint-backend-http

backend k8s-maint-backend-http
    mode tcp
    balance roundrobin
    {% for host in groups['control_nodes'] %}
    server {{ host }} {{ hostvars[host].provision_ip }}:30443 check
    {% endfor %}


# --- CEPH ACTIVE-ACTIVE NFS MESH (2049) ---
frontend ceph-nfs-front
    bind {{ k8s_api_vip }}:2049
    mode tcp
    option tcplog
    timeout client  1h
    default_backend ceph-nfs-back

backend ceph-nfs-back
    mode tcp
    balance roundrobin
    timeout server  1h
    {% for host in groups['nfs_storage_nodes'] %}
    server {{ host }} {{ hostvars[host]['provision_ip'] }}:2049 check  inter 2000 rise 2 fall 3
    {% endfor %}


